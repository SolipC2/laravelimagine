{
    "name": "solipc2/laravelimagine",
    "description": "Grok Imagine connector for Laravel — image (laravel/ai + xAI) and video (xAI) generation.",
    "type": "library",
    "keywords": [
        "laravel",
        "xai",
        "grok",
        "imagine",
        "image-generation",
        "video-generation"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "SolipC2",
            "homepage": "https://github.com/SolipC2"
        }
    ],
    "homepage": "https://github.com/SolipC2/laravelimagine",
    "support": {
        "issues": "https://github.com/SolipC2/laravelimagine/issues",
        "source": "https://github.com/SolipC2/laravelimagine"
    },
    "require": {
        "php": "^8.3",
        "illuminate/filesystem": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.9"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "SolipC2\\LaravelImagine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SolipC2\\LaravelImagine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SolipC2\\LaravelImagine\\ImagineServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/phpunit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
